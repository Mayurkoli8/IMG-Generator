# ============================================
# BrandPoster AI - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Database (SQLite for local, can swap to PostgreSQL)
DATABASE_URL="file:./dev.db"

# OpenAI API Key - Required for image generation
OPENAI_API_KEY="sk-..."

# App URL (used for generating public image URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Storage Mode: "local" | "cloudinary" | "s3"
STORAGE_MODE="local"

# --- Cloudinary (optional, if STORAGE_MODE=cloudinary) ---
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
# CLOUDINARY_FOLDER="brandposter-ai"

# --- AWS S3 (optional, if STORAGE_MODE=s3) ---
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="ap-south-1"
# AWS_S3_BUCKET="brandposter-ai"
# AWS_S3_PUBLIC_URL="https://your-bucket.s3.amazonaws.com"

# Webhook security (optional HMAC secret for n8n webhook auth)
WEBHOOK_SECRET="change-this-to-a-random-string"

# Rate limiting (requests per minute per IP for generation)
RATE_LIMIT_RPM="10"

# Max file upload size in MB
MAX_UPLOAD_MB="20"

# Image generation model (gpt-image-1 or dall-e-3)
OPENAI_IMAGE_MODEL="gpt-image-1"

# Node environment
NODE_ENV="development"
